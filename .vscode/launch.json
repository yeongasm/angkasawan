{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch",
            "type": "cppdbg",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "args": [
                "--workspace-dir", "${workspaceFolder}"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/${command:cmake.activeConfigurePresetName}/bin/",
            "MIMode": "gdb",
            "environment": [],
            "linux": {
                "type": "lldb"
            },
            "windows": {
                "type": "cppvsdbg",
                "console": "integratedTerminal"
            }
        }
    ]
}